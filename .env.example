# Home Assistant connection
HA_URL=http://homeassistant.local:8123
HA_TOKEN=your_long_lived_access_token_here

# When running as HA add-on — injected automatically, no need to set manually
# SUPERVISOR_TOKEN=

# API key for MCP clients (auto-generated on first run, saved to /config/.nexus_api_key)
# Set manually to pin it to a specific value
# NEXUS_API_KEY=

# Port for the setup web UI (default: 7123)
# NEXUS_PORT=7123

# Path to HA config directory — enables git versioning tools
# HA OS / Supervised: /config
# Local dev: path to your local HA config clone
HA_CONFIG_PATH=/config
